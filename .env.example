APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000

# --- Auth (REQUIRED in prod; generate with: python -c "import secrets;print(secrets.token_urlsafe(48))") ---
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database (prod: PostgreSQL; dev default: SQLite at repo root) ---
# For PostgreSQL via docker-compose (see below), use:
#   DATABASE_URL=postgresql+psycopg2://mbere:mbere@localhost:5432/mbere
DATABASE_URL=sqlite:///./mbere_backend.db

# --- PostgreSQL container (docker-compose `db` service) ---
# These configure the Postgres 16 container; keep them in sync with DATABASE_URL.
POSTGRES_USER=mbere
POSTGRES_PASSWORD=mbere
POSTGRES_DB=mbere
POSTGRES_PORT=5432

# --- Seed data (scripts/seed.py) ---
# Demo fleet-admin login. If SEED_ADMIN_PASSWORD is unset, a dev default is used
# and printed by the seed script.
SEED_ADMIN_EMAIL=admin@mbere.local
SEED_ADMIN_PASSWORD=ChangeMe!2026

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Model artifact to serve ---
# Leave MODEL_RUN_DIR blank to auto-select the latest run under ARTIFACTS_ROOT
# that contains {MODEL_NAME}.pkl + feature_contract.json.
ARTIFACTS_ROOT=ml/artifacts/runs
# MODEL_RUN_DIR=ml/artifacts/runs/20260628_194814_bae6def
MODEL_NAME=random_forest
